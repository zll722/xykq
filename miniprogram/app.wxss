page {
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f0f4f8;
  box-sizing: border-box;
  padding-bottom: 130rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.06), 0 1rpx 4rpx rgba(0,0,0,0.04);
  border: 1rpx solid rgba(0, 0, 0, 0.03);
}

/* Buttons */
.btn-primary {
  background: linear-gradient(135deg, #2471d6, #409EFF);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 28rpx rgba(64, 158, 255, 0.4);
  letter-spacing: 2rpx;
}

.btn-primary::after {
  border: none;
}

.btn-success {
  background: linear-gradient(135deg, #4cac1e, #67C23A);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(103, 194, 58, 0.4);
}

.btn-success::after { border: none; }

.btn-danger {
  background: linear-gradient(135deg, #e04040, #F56C6C);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  padding: 26rpx 0;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-danger::after { border: none; }

/* Text utilities */
.text-primary { color: #409EFF; }
.text-success { color: #67C23A; }
.text-warning { color: #E6A23C; }
.text-danger  { color: #F56C6C; }
.text-gray    { color: #999; }
.text-center  { text-align: center; }

/* Flex */
.flex-row     { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1       { flex: 1; }

/* Spacing */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-20 { margin-left: 20rpx; }

/* Section */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 20rpx;
  padding-left: 18rpx;
  border-left: 6rpx solid #409EFF;
  border-radius: 3rpx;
}

/* Empty state */
.empty-text {
  text-align: center;
  color: #c0c8d0;
  padding: 100rpx 0 60rpx;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-text::before {
  content: '○';
  font-size: 96rpx;
  color: #e4e8ee;
  display: block;
  margin-bottom: 24rpx;
  line-height: 1;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-success { background: #edfaf0; color: #52c41a; }
.tag-warning { background: #fff8e6; color: #e6a23c; }
.tag-danger  { background: #fff1f0; color: #f5222d; }
.tag-info    { background: #f0f4f8; color: #8c9dae; }

/* Filter bar */
.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: #888;
  transition: all 0.2s;
}

.filter-item.active {
  background: linear-gradient(135deg, #2471d6, #409EFF);
  color: #fff;
  font-weight: 700;
}

/* Record info */
.record-info {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}
