page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f0f4f8;
  box-sizing: border-box;
  padding-bottom: 130rpx;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

/* Buttons */
.btn-primary {
  background: linear-gradient(135deg, #409EFF, #2980e8);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
  width: 100%;
  box-shadow: 0 8rpx 24rpx rgba(64, 158, 255, 0.35);
}

.btn-primary::after {
  border: none;
}

.btn-success {
  background: linear-gradient(135deg, #67C23A, #4cac1e);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
}

.btn-danger {
  background: linear-gradient(135deg, #F56C6C, #e04040);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  text-align: center;
}

/* Text utilities */
.text-primary { color: #409EFF; }
.text-success { color: #67C23A; }
.text-warning { color: #E6A23C; }
.text-danger  { color: #F56C6C; }
.text-gray    { color: #999; }
.text-center  { text-align: center; }

/* Flex */
.flex-row     { display: flex; flex-direction: row; align-items: center; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-1       { flex: 1; }

/* Spacing */
.mt-20 { margin-top: 20rpx; }
.mt-40 { margin-top: 40rpx; }
.mb-20 { margin-bottom: 20rpx; }
.ml-20 { margin-left: 20rpx; }

/* Section */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 20rpx;
}

/* Empty state */
.empty-text {
  text-align: center;
  color: #bbb;
  padding: 100rpx 0 60rpx;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-text::before {
  content: '○';
  font-size: 80rpx;
  color: #e0e0e0;
  display: block;
  margin-bottom: 20rpx;
  line-height: 1;
}

/* Tags */
.tag {
  display: inline-block;
  padding: 6rpx 18rpx;
  border-radius: 10rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-success { background: #f0f9eb; color: #67C23A; }
.tag-warning { background: #fdf6ec; color: #E6A23C; }
.tag-danger  { background: #fef0f0; color: #F56C6C; }
.tag-info    { background: #f4f4f5; color: #909399; }

/* Filter bar */
.filter-bar {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #666;
  transition: all 0.2s;
}

.filter-item.active {
  background: #409EFF;
  color: #fff;
  font-weight: 600;
}

/* Record info */
.record-info {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}
