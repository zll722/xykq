.profile-header {
  text-align: center;
  padding: 56rpx 32rpx 40rpx;
}

.avatar-wrap {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #409EFF, #79bbff);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(64, 158, 255, 0.35);
}

.avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.profile-role-tag {
  display: inline-block;
  background: #ecf5ff;
  color: #409EFF;
  font-size: 24rpx;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.profile-username {
  display: block;
  font-size: 24rpx;
}

.menu-list {
  margin-top: 8rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  font-size: 30rpx;
  border-radius: 20rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
  color: #409EFF;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 40rpx;
  font-weight: 300;
}

.logout-item {
  justify-content: center;
  border: 2rpx solid #fef0f0;
  background: #fff8f8;
}

.logout-text {
  color: #F56C6C;
  font-size: 30rpx;
  font-weight: 500;
}
