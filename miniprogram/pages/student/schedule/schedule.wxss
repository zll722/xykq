.week-tabs {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.week-tab {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  font-size: 26rpx;
  color: #888;
  transition: all 0.2s;
}

.week-tab.active {
  background: #409EFF;
  color: #fff;
  font-weight: 600;
}

.course-card {
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border-left: 6rpx solid #409EFF;
  border-radius: 0 20rpx 20rpx 0;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.course-time {
  font-size: 26rpx;
  color: #409EFF;
  font-weight: 500;
}

.course-detail {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
  display: flex;
  align-items: center;
}

.ml-20 {
  margin-left: 20rpx;
}
