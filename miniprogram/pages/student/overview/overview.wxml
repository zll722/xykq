<view class="container">
  <view class="page-title-bar">
    <text class="page-title">考勤总览</text>
    <text class="page-sub">查看个人出勤统计与历史记录</text>
  </view>

  <view class="stats-section card">
    <text class="section-title">出勤统计</text>
    <view class="stats-grid">
      <view class="stat-block">
        <text class="stat-num text-primary">{{overview.totalCount || 0}}</text>
        <text class="stat-label">总课次</text>
      </view>
      <view class="stat-block">
        <text class="stat-num text-success">{{overview.presentCount || 0}}</text>
        <text class="stat-label">正常出勤</text>
      </view>
      <view class="stat-block">
        <text class="stat-num text-warning">{{overview.lateCount || 0}}</text>
        <text class="stat-label">迟到</text>
      </view>
      <view class="stat-block">
        <text class="stat-num text-danger">{{overview.absentCount || 0}}</text>
        <text class="stat-label">缺勤</text>
      </view>
    </view>
    <view class="rate-bar">
      <text class="rate-label">出勤率</text>
      <text class="rate-value text-primary">{{overview.presentRate || 0}}%</text>
    </view>
  </view>

  <view class="card query-section">
    <text class="section-title">日历查询</text>
    <view class="date-row">
      <view class="date-item">
        <text class="date-label">开始日期</text>
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="date-input picker-view">{{startDate || '请选择'}}</view>
        </picker>
      </view>
      <view class="date-item">
        <text class="date-label">结束日期</text>
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="date-input picker-view">{{endDate || '请选择'}}</view>
        </picker>
      </view>
    </view>
    <button class="btn-primary query-btn" bindtap="onQuery" loading="{{querying}}">查询记录</button>
  </view>

  <view wx:if="{{calendar.length > 0}}" class="card">
    <text class="section-title">查询结果（{{calendar.length}} 条）</text>
    <view class="calendar-list">
      <view wx:for="{{calendar}}" wx:key="index" class="cal-item">
        <view class="cal-left">
          <text class="cal-date">{{item.attendanceDate}}</text>
          <text class="cal-course">{{item.courseName || '未命名课程'}}</text>
        </view>
        <text class="tag {{item.status === 'PRESENT' ? 'tag-success' : ((item.status === 'LATE' || item.status === 'EARLY_LEAVE') ? 'tag-warning' : (item.status === 'LEAVE' ? 'tag-info' : 'tag-danger'))}}">
          {{item.status === 'PRESENT' ? '正常' : (item.status === 'LATE' ? '迟到' : (item.status === 'EARLY_LEAVE' ? '早退' : (item.status === 'LEAVE' ? '请假' : '缺勤')))}}
        </text>
      </view>
    </view>
  </view>

  <view wx:if="{{calendar.length === 0 && !querying}}" class="empty-text">暂无考勤记录，可设置日期范围后查询</view>
</view>
