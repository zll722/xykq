.sign-card {
  text-align: center;
  padding: 60rpx 40rpx 80rpx;
  margin-top: 40rpx;
}

.course-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
  color: #222;
}

.sign-time {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 80rpx;
  font-variant-numeric: tabular-nums;
  letter-spacing: 2rpx;
}

.sign-btn-wrap {
  display: flex;
  justify-content: center;
}

.sign-btn {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2980e8, #409EFF);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 48rpx rgba(64, 158, 255, 0.45),
              0 0 0 16rpx rgba(64, 158, 255, 0.08);
  border: none;
  padding: 0;
}

.sign-btn::after {
  border: none;
}

.sign-btn-text {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
}

.sign-result {
  padding: 40rpx 0;
}

.result-icon {
  display: block;
  font-size: 100rpx;
  margin-bottom: 24rpx;
  line-height: 1;
}

.result-text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  color: #222;
}

.result-time {
  display: block;
  font-size: 28rpx;
  color: #999;
}
