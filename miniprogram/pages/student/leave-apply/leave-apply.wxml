<view class="container">
  <view class="nav-links">
    <view class="nav-link" bindtap="goHistory">请假记录</view>
    <view class="nav-link" bindtap="goProgress">审批进度</view>
  </view>

  <view class="card">
    <view class="form-item">
      <text class="form-label">请假类型</text>
      <picker mode="selector" range="{{leaveTypes}}" range-key="label" bindchange="onTypeChange">
        <view class="form-input picker-view">{{selectedType || '请选择请假类型'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">快捷时间方案</text>
      <view class="preset-group">
        <view class="preset-btn" bindtap="applyPreset" data-preset="morningToday">今天上午</view>
        <view class="preset-btn" bindtap="applyPreset" data-preset="afternoonToday">今天下午</view>
        <view class="preset-btn" bindtap="applyPreset" data-preset="allDayTomorrow">明天全天</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">开始时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{startDate}}" bindchange="onStartDateChange">
          <view class="form-input picker-view datetime-half">{{startDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{startClock}}" bindchange="onStartTimeChange">
          <view class="form-input picker-view datetime-half">{{startClock || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">结束时间</text>
      <view class="datetime-row">
        <picker mode="date" value="{{endDate}}" bindchange="onEndDateChange">
          <view class="form-input picker-view datetime-half">{{endDate || '选择日期'}}</view>
        </picker>
        <picker mode="time" value="{{endClock}}" bindchange="onEndTimeChange">
          <view class="form-input picker-view datetime-half">{{endClock || '选择时间'}}</view>
        </picker>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">请假原因</text>
      <textarea class="form-textarea" placeholder="请输入请假原因" value="{{form.reason}}" bindinput="onReasonInput" maxlength="500" />
    </view>

    <view class="form-item">
      <text class="form-label">附件（可选）</text>
      <button class="btn-upload" bindtap="chooseFile">选择文件</button>
      <text wx:if="{{attachment}}" class="file-name">{{attachment}}</text>
    </view>

    <button class="btn-primary mt-40" bindtap="submitLeave" loading="{{loading}}">提交申请</button>
  </view>
</view>
<custom-tabbar role="USER" currentIndex="{{2}}" />
