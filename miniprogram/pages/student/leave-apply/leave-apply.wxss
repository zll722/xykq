.nav-links {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.nav-link {
  padding: 16rpx 32rpx;
  background: #fff;
  border-radius: 14rpx;
  font-size: 26rpx;
  color: #409EFF;
  font-weight: 500;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-item {
  margin-bottom: 36rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #444;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  height: 88rpx;
  border: 2rpx solid #e8ecf0;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.picker-view {
  color: #333;
  line-height: 88rpx;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  border: 2rpx solid #e8ecf0;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.btn-upload {
  display: inline-block;
  padding: 14rpx 36rpx;
  background: #f0f8ff;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #409EFF;
  border: 1rpx dashed #409EFF;
}

.btn-upload::after {
  border: none;
}

.file-name {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #409EFF;
}
