.date-filter {
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #333;
  border: 2rpx solid #e8ecf0;
  text-align: center;
}

.date-sep {
  font-size: 26rpx;
  color: #888;
  flex-shrink: 0;
}

.date-clear {
  font-size: 24rpx;
  color: #409EFF;
  padding: 8rpx 16rpx;
  flex-shrink: 0;
}

.record-card {
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.record-course {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.record-info {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}

.ml-20 {
  margin-left: 20rpx;
}
