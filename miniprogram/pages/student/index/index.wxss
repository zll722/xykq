.welcome-card {
  background: linear-gradient(135deg, #2980e8, #409EFF);
  color: #fff;
  padding: 40rpx;
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(64, 158, 255, 0.35);
}

.welcome-text {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.welcome-sub {
  display: block;
  font-size: 26rpx;
  opacity: 0.85;
}

.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-item {
  text-align: center;
  padding: 28rpx 16rpx;
}

.approval-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
}

.approval-label {
  font-size: 26rpx;
  color: #888;
}

.approval-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.text-info { color: #409EFF; }

.stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.section {
  margin-bottom: 24rpx;
}

.course-card {
  padding: 28rpx;
  border-left: 6rpx solid #409EFF;
  border-radius: 0 20rpx 20rpx 0;
  margin-bottom: 16rpx;
}

.course-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.course-info {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #888;
}

.ml-20 {
  margin-left: 20rpx;
}

.quick-actions {
  margin-top: 32rpx;
}
