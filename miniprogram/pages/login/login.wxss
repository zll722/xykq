.login-page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a6fce 0%, #409EFF 45%, #79bbff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.login-hero {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 32rpx;
  backdrop-filter: blur(10px);
}

.logo-icon {
  font-size: 72rpx;
  color: #fff;
  line-height: 1;
}

.login-title {
  display: block;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.login-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.login-form {
  width: 100%;
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 48rpx 48rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

.form-item {
  margin-bottom: 32rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  border: 2rpx solid #e8ecf0;
  border-radius: 16rpx;
  padding: 0 28rpx;
  background: #f8fafc;
  height: 96rpx;
}

.input-prefix {
  font-size: 28rpx;
  color: #409EFF;
  font-weight: 600;
  margin-right: 20rpx;
  width: 32rpx;
  text-align: center;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  color: #333;
  background: transparent;
}

.login-btn {
  margin-top: 48rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 34rpx;
  border-radius: 16rpx;
}

.login-footer {
  display: block;
  margin-top: 48rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
}
