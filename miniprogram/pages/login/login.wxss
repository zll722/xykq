.login-page {
  min-height: 100vh;
  background: linear-gradient(150deg, #0f4c9e 0%, #1a6fce 40%, #3a9eff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx 60rpx;
  position: relative;
  overflow: hidden;
}

/* 背景装饰圆 */
.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  top: -180rpx;
  right: -120rpx;
}
.bg-circle-2 {
  width: 320rpx;
  height: 320rpx;
  bottom: 120rpx;
  left: -100rpx;
  background: rgba(255, 255, 255, 0.04);
}
.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 30%;
  right: 60rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255,255,255,0.1);
}

/* Logo */
.login-hero {
  text-align: center;
  margin-bottom: 56rpx;
  z-index: 1;
}

.logo-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 32rpx;
}

.logo-ring-outer {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-ring-inner {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(12px);
}

.logo-icon {
  font-size: 60rpx;
  color: #fff;
  line-height: 1;
}

.login-title {
  display: block;
  font-size: 54rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
}

.login-subtitle {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 3rpx;
}

/* 表单卡片 */
.login-card {
  width: 100%;
  background: #fff;
  border-radius: 36rpx;
  padding: 56rpx 48rpx 48rpx;
  box-shadow: 0 32rpx 80rpx rgba(0, 0, 0, 0.22), 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 1;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 40rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #f5f7fb;
  border-radius: 18rpx;
  height: 100rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #409EFF, #2471d6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(64,158,255,0.35);
}

.input-icon-txt {
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
}

.form-input {
  flex: 1;
  height: 100rpx;
  font-size: 30rpx;
  color: #2c2c3e;
  background: transparent;
}

.input-ph {
  color: #bfc8d6;
}

.btn-login {
  margin-top: 16rpx;
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 34rpx;
  font-weight: 700;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2471d6, #409EFF, #60b8ff);
  color: #fff;
  border: none;
  box-shadow: 0 12rpx 36rpx rgba(64, 158, 255, 0.5);
  letter-spacing: 4rpx;
}

.btn-login::after {
  border: none;
}

.login-footer {
  display: block;
  margin-top: 52rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  text-align: center;
  z-index: 1;
}

.login-links {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32rpx;
  padding: 0 10rpx;
}

.register-tip {
  display: flex;
  justify-content: center;
  align-items: center;
}

.register-tip-text {
  font-size: 26rpx;
  color: #7a8ca0;
}

.register-tip-link {
  font-size: 26rpx;
  color: #2471d6;
  font-weight: 700;
  margin-left: 4rpx;
}
