<view class="login-page">
  <view class="login-hero">
    <view class="logo-circle">
      <text class="logo-icon">◎</text>
    </view>
    <text class="login-title">智能校园考勤</text>
    <text class="login-subtitle">Smart Campus Attendance</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <view class="input-wrap">
        <text class="input-prefix">账</text>
        <input class="form-input" placeholder="请输入账号" value="{{username}}" bindinput="onUsernameInput" />
      </view>
    </view>
    <view class="form-item">
      <view class="input-wrap">
        <text class="input-prefix">密</text>
        <input class="form-input" placeholder="请输入密码" password="{{true}}" value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>
    <button class="btn-primary login-btn" bindtap="onLogin" loading="{{loading}}">登 录</button>
  </view>

  <text class="login-footer">智能校园管理系统 · 考勤模块</text>
</view>
