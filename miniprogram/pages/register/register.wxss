.register-page {
  min-height: 100vh;
  background: linear-gradient(150deg, #0f4c9e 0%, #1a6fce 40%, #3a9eff 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 80rpx;
  position: relative;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}
.bg-circle-1 {
  width: 500rpx;
  height: 500rpx;
  top: -180rpx;
  right: -120rpx;
}
.bg-circle-2 {
  width: 320rpx;
  height: 320rpx;
  bottom: 120rpx;
  left: -100rpx;
  background: rgba(255, 255, 255, 0.04);
}
.bg-circle-3 {
  width: 200rpx;
  height: 200rpx;
  top: 30%;
  right: 60rpx;
  background: rgba(255, 255, 255, 0.05);
  border: 2rpx solid rgba(255,255,255,0.1);
}

.register-hero {
  text-align: center;
  margin-bottom: 44rpx;
  z-index: 1;
}

.logo-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-ring-outer {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-ring-inner {
  width: 106rpx;
  height: 106rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  border: 2rpx solid rgba(255, 255, 255, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 50rpx;
  color: #fff;
}

.register-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 8rpx;
  letter-spacing: 6rpx;
}

.register-subtitle {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 2rpx;
}

.register-card {
  width: 100%;
  background: #fff;
  border-radius: 36rpx;
  padding: 48rpx 48rpx 40rpx;
  box-shadow: 0 32rpx 80rpx rgba(0, 0, 0, 0.22), 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 1;
}

.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 36rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #35506b;
  margin-bottom: 12rpx;
}

.input-row {
  display: flex;
  align-items: center;
  background: #f5f7fb;
  border-radius: 18rpx;
  height: 96rpx;
  padding: 0 24rpx;
  border: 2rpx solid transparent;
}

.input-icon-box {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #409EFF, #2471d6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(64,158,255,0.35);
}

.input-icon-txt {
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.form-input {
  flex: 1;
  height: 96rpx;
  font-size: 28rpx;
  color: #2c2c3e;
  background: transparent;
}

.input-ph {
  color: #bfc8d6;
}

.picker-row {
  display: flex;
  align-items: center;
  background: #f5f7fb;
  border-radius: 18rpx;
  height: 96rpx;
  padding: 0 28rpx;
  border: 2rpx solid transparent;
}

.picker-ph {
  flex: 1;
  font-size: 28rpx;
  color: #bfc8d6;
}

.picker-val {
  flex: 1;
  font-size: 28rpx;
  color: #2c2c3e;
}

.picker-arrow {
  font-size: 40rpx;
  color: #99aabb;
  line-height: 1;
}

.btn-register {
  margin-top: 20rpx;
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #2471d6, #409EFF, #60b8ff);
  color: #fff;
  border: none;
  box-shadow: 0 12rpx 36rpx rgba(64, 158, 255, 0.5);
  letter-spacing: 4rpx;
}

.btn-register::after {
  border: none;
}

.login-tip {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-top: 32rpx;
}

.login-tip-text {
  font-size: 26rpx;
  color: #7a8ca0;
}

.login-tip-link {
  font-size: 26rpx;
  color: #2471d6;
  font-weight: 600;
  margin-left: 4rpx;
}
