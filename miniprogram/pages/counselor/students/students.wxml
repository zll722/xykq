<view class="container">
  <view wx:if="{{students.length === 0}}" class="empty-text">暂无学生数据</view>
  <view wx:for="{{students}}" wx:key="userId" class="card student-card">
    <view class="flex-between">
      <view>
        <text class="student-name">{{item.realName}}</text>
        <text class="student-no">{{item.studentNo}}</text>
      </view>
      <text wx:if="{{item.phone}}" class="phone text-gray">{{item.phone}}</text>
    </view>
    <view class="attendance-stats">
      <view class="stat-badge present">
        <text class="stat-num">{{item.presentCount || 0}}</text>
        <text class="stat-lbl">正常</text>
      </view>
      <view class="stat-badge late">
        <text class="stat-num">{{item.lateCount || 0}}</text>
        <text class="stat-lbl">迟到</text>
      </view>
      <view class="stat-badge absent">
        <text class="stat-num">{{item.absentCount || 0}}</text>
        <text class="stat-lbl">缺勤</text>
      </view>
      <view class="stat-badge leave">
        <text class="stat-num">{{item.leaveCount || 0}}</text>
        <text class="stat-lbl">请假</text>
      </view>
    </view>
  </view>
</view>
