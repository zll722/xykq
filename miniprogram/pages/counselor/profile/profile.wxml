<view class="container">
  <view class="profile-header card">
    <view class="avatar-wrap" bindtap="chooseAvatar">
      <image wx:if="{{profile.avatarUrl}}" class="avatar-img" src="{{profile.avatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder counselor">
        <text class="avatar-text">{{profile.realName ? profile.realName.slice(0, 1) : (userInfo.realName ? userInfo.realName.slice(0, 1) : '导')}}</text>
      </view>
      <view class="avatar-edit-tag">换头像</view>
    </view>
    <text class="profile-name">{{profile.realName || userInfo.realName || '辅导员'}}</text>
    <text class="profile-role-tag counselor-tag">辅导员</text>
    <text class="profile-username text-gray">账号：{{userInfo.username || ''}}</text>
  </view>

  <view class="card edit-form">
    <text class="form-title">编辑资料</text>
    <view class="form-item">
      <text class="form-label">姓名</text>
      <input class="form-input" value="{{profile.realName}}" placeholder="请输入真实姓名" bindinput="onInput" data-field="realName" />
    </view>
    <view class="form-item">
      <text class="form-label">手机号</text>
      <input class="form-input" value="{{profile.phone}}" placeholder="请输入手机号" bindinput="onInput" data-field="phone" type="number" />
    </view>
    <view class="form-item">
      <text class="form-label">邮箱</text>
      <input class="form-input" value="{{profile.email}}" placeholder="请输入邮箱" bindinput="onInput" data-field="email" />
    </view>
    <button class="btn-save" bindtap="saveProfile" loading="{{saving}}">保存资料</button>
  </view>

  <view class="menu-list">
    <view class="menu-item card" bindtap="goClasses">
      <view class="menu-left">
        <text class="menu-icon">▦</text>
        <text class="menu-label">班级管理</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item card" bindtap="goHistory">
      <view class="menu-left">
        <text class="menu-icon">◧</text>
        <text class="menu-label">审批历史</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item card" bindtap="goChangePassword">
      <view class="menu-left">
        <text class="menu-icon">◎</text>
        <text class="menu-label">修改密码</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item card logout-item" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
<custom-tabbar role="COUNSELOR" currentIndex="{{3}}" />
