.profile-header {
  text-align: center;
  padding: 56rpx 32rpx 48rpx;
  background: linear-gradient(145deg, #0d7a5a, #18a876, #3ecf9e) !important;
  border-radius: 28rpx !important;
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: -80rpx;
  left: -40rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.06);
}

.avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 24rpx;
}

.avatar-placeholder {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  border: 4rpx solid rgba(255,255,255,0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}

.avatar-placeholder.counselor {
  background: rgba(255,255,255,0.2);
}

.avatar-text {
  font-size: 60rpx;
  color: #fff;
  font-weight: 800;
}

.avatar-img {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.7);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
}

.avatar-edit-tag {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.45);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 18rpx;
  border-radius: 12rpx;
  white-space: nowrap;
}

.profile-name {
  display: block;
  font-size: 42rpx;
  font-weight: 800;
  color: #fff;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.profile-role-tag {
  display: inline-block;
  background: rgba(255,255,255,0.22);
  color: #fff;
  font-size: 24rpx;
  padding: 6rpx 28rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255,255,255,0.4);
  position: relative;
  z-index: 1;
}

.profile-role-tag.counselor-tag {
  background: rgba(255,255,255,0.22);
  color: #fff;
}

.profile-username {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
  position: relative;
  z-index: 1;
}

.edit-form { padding: 32rpx; }

.form-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a2e;
  margin-bottom: 28rpx;
  padding-left: 16rpx;
  border-left: 5rpx solid #18a876;
}

.form-item { margin-bottom: 24rpx; }

.form-label {
  display: block;
  font-size: 24rpx;
  color: #8c9dae;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 84rpx;
  background: #f5f7fb;
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2c2c3e;
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #0d7a5a, #18a876);
  color: #fff;
  border: none;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 168, 118, 0.4);
}

.btn-save::after { border: none; }

.menu-list { margin-top: 8rpx; }

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  font-size: 30rpx;
  border-radius: 20rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.menu-icon-box {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #18a876, #0d7a5a);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 14rpx rgba(24,168,118,0.3);
}

.menu-icon {
  font-size: 32rpx;
  color: #fff;
  width: auto;
  text-align: center;
}

.menu-label {
  font-size: 30rpx;
  color: #2c3e50;
  font-weight: 500;
}

.menu-arrow {
  color: #d0dae4;
  font-size: 44rpx;
  font-weight: 300;
}

.logout-item {
  justify-content: center;
  border: 1rpx solid #ffe8e8;
  background: #fff8f8;
}

.logout-text {
  color: #F56C6C;
  font-size: 30rpx;
  font-weight: 600;
}
