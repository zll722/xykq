.profile-header {
  text-align: center;
  padding: 56rpx 32rpx 40rpx;
}

.avatar-wrap {
  margin-bottom: 24rpx;
  display: flex;
  justify-content: center;
}

.avatar-placeholder {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #409EFF, #79bbff);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(64, 158, 255, 0.35);
}

.avatar-placeholder.counselor {
  background: linear-gradient(135deg, #1a8f6c, #28b48a);
  box-shadow: 0 8rpx 32rpx rgba(40, 180, 138, 0.35);
}

.avatar-text {
  font-size: 56rpx;
  color: #fff;
  font-weight: 700;
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.profile-role-tag {
  display: inline-block;
  background: #ecf5ff;
  color: #409EFF;
  font-size: 24rpx;
  padding: 6rpx 24rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.profile-role-tag.counselor-tag {
  background: #e6f9f4;
  color: #28b48a;
}

.profile-username {
  display: block;
  font-size: 24rpx;
}

.menu-list {
  margin-top: 8rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  font-size: 30rpx;
  border-radius: 20rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
  color: #28b48a;
  width: 48rpx;
  text-align: center;
}

.menu-label {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-size: 40rpx;
  font-weight: 300;
}

.logout-item {
  justify-content: center;
  border: 2rpx solid #fef0f0;
  background: #fff8f8;
}

.logout-text {
  color: #F56C6C;
  font-size: 30rpx;
  font-weight: 500;
}

.avatar-img {
  width: 144rpx;
  height: 144rpx;
  border-radius: 50%;
}

.avatar-edit-tag {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 10rpx;
  white-space: nowrap;
}

.avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 24rpx;
}

.edit-form {
  padding: 32rpx;
}

.form-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 28rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.btn-save {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #28b48a, #1a8f6c);
  color: #fff;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  margin-top: 16rpx;
  box-shadow: 0 6rpx 20rpx rgba(40, 180, 138, 0.35);
}

.btn-save::after {
  border: none;
}
