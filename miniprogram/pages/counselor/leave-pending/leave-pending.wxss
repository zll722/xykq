.leave-card {
  border-radius: 20rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.student-no {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.leave-info {
  font-size: 26rpx;
  color: #666;
}

.leave-reason {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #888;
  line-height: 1.6;
}

.submit-time {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.action-row {
  border-top: 2rpx solid #f5f5f5;
  padding-top: 24rpx;
  margin-top: 8rpx;
}

.remark-input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e8ecf0;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
  background: #f8fafc;
}

.action-btns {
  display: flex;
  gap: 20rpx;
}

.btn-approve {
  flex: 1;
  background: linear-gradient(135deg, #4cac1e, #67C23A);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(103, 194, 58, 0.35);
}

.btn-approve::after {
  border: none;
}

.btn-reject {
  flex: 1;
  background: linear-gradient(135deg, #e04040, #F56C6C);
  color: #fff;
  border: none;
  border-radius: 14rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  box-shadow: 0 4rpx 16rpx rgba(245, 108, 108, 0.35);
}

.btn-reject::after {
  border: none;
}
