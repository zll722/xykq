<view class="forgot-page">
  <!-- 背景装饰圆 -->
  <view class="bg-circle bg-circle-1"></view>
  <view class="bg-circle bg-circle-2"></view>
  <view class="bg-circle bg-circle-3"></view>

  <view class="forgot-hero">
    <view class="logo-wrap">
      <view class="logo-ring-outer">
        <view class="logo-ring-inner">
          <text class="logo-icon">✦</text>
        </view>
      </view>
    </view>
    <text class="forgot-title">找回密码</text>
    <text class="forgot-subtitle">Smart Campus Attendance</text>
  </view>

  <view class="forgot-card">
    <text class="card-title">重置登录密码</text>

    <view class="form-item">
      <text class="form-label">登录账号</text>
      <view class="input-row">
        <view class="input-icon-box"><text class="input-icon-txt">账</text></view>
        <input class="form-input" placeholder="请输入您的登录账号" placeholder-class="input-ph"
          value="{{username}}" bindinput="onUsernameInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">绑定邮箱</text>
      <view class="input-row">
        <view class="input-icon-box"><text class="input-icon-txt">邮</text></view>
        <input class="form-input" placeholder="请输入绑定的邮箱" placeholder-class="input-ph"
          value="{{email}}" bindinput="onEmailInput" type="text" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">验证码</text>
      <view class="input-row code-row">
        <view class="input-icon-box"><text class="input-icon-txt">验</text></view>
        <input class="form-input code-input" placeholder="请输入6位验证码" placeholder-class="input-ph"
          value="{{code}}" bindinput="onCodeInput" maxlength="6" />
        <button class="btn-send-code" hover-class="btn-send-code-hover" disabled="{{countdown > 0 || sendingCode}}" bindtap="sendCode">
          {{ countdown > 0 ? countdown + 's后重试' : '获取验证码' }}
        </button>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">新密码</text>
      <view class="input-row">
        <view class="input-icon-box"><text class="input-icon-txt">锁</text></view>
        <input class="form-input" placeholder="请输入新密码（不少于6位）" placeholder-class="input-ph"
          password="{{true}}" value="{{newPassword}}" bindinput="onNewPasswordInput" />
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">确认新密码</text>
      <view class="input-row">
        <view class="input-icon-box"><text class="input-icon-txt">确</text></view>
        <input class="form-input" placeholder="请再次输入新密码" placeholder-class="input-ph"
          password="{{true}}" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
    </view>

    <button class="btn-submit" bindtap="onSubmit" loading="{{loading}}">确 认 重 置</button>

    <view class="login-tip" bindtap="goLogin">
      <text class="login-tip-text">记起密码了？</text>
      <text class="login-tip-link">返回登录</text>
    </view>
  </view>
</view>
