.class-item {
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.class-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.class-code {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
}

.menu-arrow {
  color: #ccc;
  font-size: 36rpx;
  font-weight: 300;
}

.record-item {
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.student-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.student-no {
  display: block;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.attend-rate {
  text-align: center;
}

.rate-text {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #409EFF;
}

.rate-label {
  display: block;
  font-size: 22rpx;
}

.attendance-stats {
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.stat-badge {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 12rpx;
}

.stat-badge.present { background: #f0f9eb; }
.stat-badge.late    { background: #fdf6ec; }
.stat-badge.absent  { background: #fef0f0; }
.stat-badge.leave   { background: #f4f4f5; }

.stat-num {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.stat-badge.present .stat-num { color: #67C23A; }
.stat-badge.late    .stat-num { color: #E6A23C; }
.stat-badge.absent  .stat-num { color: #F56C6C; }
.stat-badge.leave   .stat-num { color: #909399; }

.stat-lbl {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}
