<view class="container">
  <view class="profile-header card">
    <view class="avatar-wrap">
      <view class="avatar-placeholder">
        <text class="avatar-text">{{userInfo.realName ? userInfo.realName.slice(0, 1) : '师'}}</text>
      </view>
    </view>
    <text class="profile-name">{{userInfo.realName || '教师'}}</text>
    <text class="profile-role-tag">教师</text>
    <text class="profile-username text-gray">账号：{{userInfo.username || ''}}</text>
  </view>

  <view class="menu-list">
    <view class="menu-item card" bindtap="goClasses">
      <view class="menu-left">
        <text class="menu-icon">◫</text>
        <text class="menu-label">我的班级</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item card" bindtap="goChangePassword">
      <view class="menu-left">
        <text class="menu-icon">◎</text>
        <text class="menu-label">修改密码</text>
      </view>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item card logout-item" bindtap="onLogout">
      <text class="logout-text">退出登录</text>
    </view>
  </view>
</view>
<custom-tabbar role="TEACHER" currentIndex="{{3}}" />
