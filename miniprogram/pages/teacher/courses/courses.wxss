.course-card {
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.course-header {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.course-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.course-code {
  font-size: 22rpx;
}

.course-meta {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.meta-icon {
  font-size: 28rpx;
  color: #909399;
  width: 36rpx;
  text-align: center;
}

.meta-text {
  font-size: 26rpx;
  color: #555;
}

.course-footer {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 14rpx;
}

.student-count {
  font-size: 24rpx;
  font-weight: 600;
}
