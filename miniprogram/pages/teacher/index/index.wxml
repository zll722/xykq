<view class="container">
  <view class="welcome-card card">
    <text class="welcome-text">教师工作台</text>
    <text class="welcome-sub">{{userInfo.realName || '老师'}}，欢迎回来</text>
  </view>

  <view class="stats-row">
    <view class="stat-item card">
      <text class="stat-value text-primary">{{stats.classCount || 0}}</text>
      <text class="stat-label">授课班级</text>
    </view>
    <view class="stat-item card">
      <text class="stat-value text-success">{{stats.courseCount || 0}}</text>
      <text class="stat-label">授课门数</text>
    </view>
    <view class="stat-item card">
      <text class="stat-value text-warning">{{stats.todayLeaveCount || 0}}</text>
      <text class="stat-label">今日请假</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">快捷入口</text>
    <view class="quick-grid">
      <view class="quick-item card" bindtap="goClasses">
        <text class="quick-icon">◫</text>
        <text class="quick-text">我的班级</text>
      </view>
      <view class="quick-item card" bindtap="goReport">
        <text class="quick-icon">▤</text>
        <text class="quick-text">考勤报表</text>
      </view>
      <view class="quick-item card" bindtap="goLeave">
        <text class="quick-icon">◈</text>
        <text class="quick-text">请假通知</text>
      </view>
    </view>
  </view>
</view>
<custom-tabbar role="TEACHER" currentIndex="{{0}}" />
