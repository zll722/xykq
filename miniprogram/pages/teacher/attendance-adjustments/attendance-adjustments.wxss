.filter-section {
  padding: 10rpx 30rpx 30rpx;
  margin-bottom: 20rpx;
}

.filter-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.border-none {
  border-bottom: none;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
}

.filter-value {
  font-size: 28rpx;
}

.record-card {
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.record-detail {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  background-color: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
}

.label {
  display: inline-block;
  width: 100rpx;
}

.action-bar {
  display: flex;
  justify-content: flex-end;
}

.btn-small {
  padding: 0 40rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 26rpx;
  background-color: #f5f5f5;
  color: #666;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-dialog {
  width: 85%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  padding: 0 20rpx;
}

.modal-content {
  padding: 30rpx;
}

.info-card {
  background: #fdf6ec;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  border: 1px solid #faecd8;
}

.info-text {
  display: block;
  font-size: 26rpx;
  color: #e6a23c;
  line-height: 1.6;
}

.form-group {
  margin-bottom: 20rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.picker-box {
  background: #f5f7fa;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333;
  border: 1px solid #e4e7ed;
}

.textarea-box {
  width: 100%;
  background: #f5f7fa;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  height: 160rpx;
  box-sizing: border-box;
  border: 1px solid #e4e7ed;
}

.modal-footer {
  display: flex;
  padding: 0 30rpx 30rpx;
}

.modal-footer .btn {
  flex: 1;
}

.btn-cancel {
  background: #f5f5f5;
  color: #666;
}

.ml-20 {
  margin-left: 20rpx;
}
