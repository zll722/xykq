<view class="tabbar">
  <view
    class="tabbar-item {{currentIndex === index ? 'active' : ''}}"
    wx:for="{{tabs}}"
    wx:key="index"
    bindtap="onTabTap"
    data-index="{{index}}"
    data-path="{{item.path}}"
  >
    <view class="tabbar-icon-wrap">
      <text class="tabbar-icon {{currentIndex === index ? 'icon-active' : ''}}">{{currentIndex === index ? item.activeIcon : item.icon}}</text>
      <view wx:if="{{currentIndex === index}}" class="active-dot"></view>
    </view>
    <text class="tabbar-text">{{item.text}}</text>
  </view>
</view>
