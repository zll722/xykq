<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.attendance.mapper.SystemConfigMapper">

    <resultMap id="SystemConfigMap" type="com.campus.attendance.domain.SystemConfig">
        <id property="id" column="id"/>
        <result property="configKey" column="config_key"/>
        <result property="configValue" column="config_value"/>
        <result property="configName" column="config_name"/>
        <result property="remark" column="remark"/>
        <result property="updatedBy" column="updated_by"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="listAll" resultMap="SystemConfigMap">
        SELECT id, config_key, config_value, config_name, remark, updated_by, updated_at
        FROM sys_config
        ORDER BY id ASC
    </select>

    <update id="updateValue">
        UPDATE sys_config
        SET config_value = #{configValue},
            updated_by = #{updatedBy}
        WHERE config_key = #{configKey}
    </update>
</mapper>
