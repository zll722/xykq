<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.campus.attendance.mapper.StudentProfileMapper">
    <select id="findClassIdByUserId" resultType="java.lang.Long">
        SELECT class_id
        FROM student_profile
        WHERE user_id = #{userId}
        LIMIT 1
    </select>
</mapper>
